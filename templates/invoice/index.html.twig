{% extends 'base.html.twig' %}

{% block title %}Invoices{% endblock %}

{% block body %}
    <section class="page-header">
        <div>
            <p class="eyebrow">Invoices</p>
            <h1>Invoice pipeline</h1>
        </div>
        <a class="button" href="{{ path('app_invoice_new') }}">Create invoice</a>
    </section>

    <section class="panel">
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Number</th>
                        <th>Client</th>
                        <th>Status</th>
                        <th>Amount</th>
                        <th>Due</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for invoice in invoices %}
                        <tr>
                            <td>{{ invoice.number }}</td>
                            <td>{{ invoice.client.company }}</td>
                            <td><span class="pill pill--{{ invoice.status }}">{{ invoice.status|title }}</span></td>
                            <td>EUR {{ invoice.amount }}</td>
                            <td>{{ invoice.dueAt|date('Y-m-d') }}</td>
                            <td><a href="{{ path('app_invoice_show', {id: invoice.id}) }}">View</a></td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="muted">No invoices created yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
