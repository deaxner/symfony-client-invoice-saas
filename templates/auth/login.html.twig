{% extends 'base.html.twig' %}

{% block title %}Sign In{% endblock %}

{% block body %}
    <section class="auth-card">
        <div>
            <p class="eyebrow">SaaS workspace</p>
            <h1>Sign in to manage clients and invoices</h1>
            <p class="muted">Track clients, invoice status, and revenue from one Symfony workspace.</p>
        </div>

        <form method="post" class="form-card">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <label class="field">
                <span>Email</span>
                <input type="email" name="email" value="{{ last_username }}" required autofocus>
            </label>

            <label class="field">
                <span>Password</span>
                <input type="password" name="password" required>
            </label>

            {% if error %}
                <div class="flash flash--error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <button class="button" type="submit">Sign in</button>
            <p class="muted">No account yet? <a href="{{ path('app_register') }}">Create one</a></p>
        </form>
    </section>
{% endblock %}
